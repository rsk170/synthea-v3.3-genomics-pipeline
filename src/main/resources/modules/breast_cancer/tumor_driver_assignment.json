{
  "name": "Tumor_Driver_Assignment",
  "remarks": [
    "Assigns 1–3 tumor driver genes after a biopsy/genomic profiling step. Emits LOINC 69548-6 observations."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Tumor_Genome_Sequencing_Biopsy"
    },

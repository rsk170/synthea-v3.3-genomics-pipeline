      "type": "Procedure",
      "reason": "breast_cancer_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "733505001",
          "display": "Tumor genomic profile (procedure)"
        }
      ],
      "direct_transition": "Determine_Number_Of_Drivers"
    },
    "Determine_Number_Of_Drivers": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Assign_1_Drivers",
          "distribution": 0.5
        },
        {
          "transition": "Assign_2_Drivers",
          "distribution": 0.3
        },
        {
          "transition": "Assign_3_Drivers",
          "distribution": 0.2
        }
      ]
    },
    "Assign_1_Drivers": {
      "type": "SetAttribute",

{
  "name": "Tumor_Driver_Assignment",
  "remarks": [
    "Assigns 1–6 tumor driver genes after tumor genomic profiling. Emits LOINC 69548-6 observations.",
    "Uses a target counter plus an assigned counter to avoid repeating the same logic for each driver slot."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Tumor_Genome_Sequencing_Biopsy"
    },
    "Tumor_Genome_Sequencing_Biopsy": {
      "type": "Procedure",
      "reason": "breast_cancer_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "733505001",
          "display": "Tumor genomic profile (procedure)"
        }
      ],
      "direct_transition": "Determine_Number_Of_Drivers"
    },
    "Determine_Number_Of_Drivers": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Assign_1_Drivers",
          "distribution": 0.35
        },
        {
          "transition": "Assign_2_Drivers",
          "distribution": 0.25
        },
        {
          "transition": "Assign_3_Drivers",
          "distribution": 0.15
        },
        {
          "transition": "Assign_4_Drivers",
          "distribution": 0.10
        },
        {
          "transition": "Assign_5_Drivers",
          "distribution": 0.08
        },
        {
          "transition": "Assign_6_Drivers",
          "distribution": 0.07
        }
      ]
    },
    "Assign_1_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 1,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Assign_2_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 2,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Assign_3_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 3,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Assign_4_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 4,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Assign_5_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 5,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Assign_6_Drivers": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_target",
      "value": 6,
      "direct_transition": "Initialize_Assigned_Driver_Count"
    },
    "Initialize_Assigned_Driver_Count": {
      "type": "SetAttribute",
      "attribute": "tumor_driver_assigned",
      "value": 0,
      "direct_transition": "Driver_Assignment_Gate"
    },
    "Driver_Assignment_Gate": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 0
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 1
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 1
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 2
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 2
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 3
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 3
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 4
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 4
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 5
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_assigned",
                "operator": "==",
                "value": 5
              },
              {
                "condition_type": "Attribute",
                "attribute": "tumor_driver_target",
                "operator": ">=",
                "value": 6
              }
            ]
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "transition": "Terminal"
        }
      ]
    },
    "Select_Driver_Gene": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Check_TP53",
          "distribution": 0.20
        },
        {
          "transition": "Check_PIK3CA",
          "distribution": 0.10
        },
        {
          "transition": "Check_ARID1A",
          "distribution": 0.10
        },
        {
          "transition": "Check_CCND1",
          "distribution": 0.10
        },
        {
          "transition": "Check_PTEN",
          "distribution": 0.10
        },
        {
          "transition": "Check_YWHAZ",
          "distribution": 0.10
        },
        {
          "transition": "Check_MYC",
          "distribution": 0.10
        },
        {
          "transition": "Check_GATA3",
          "distribution": 0.10
        },
        {
          "transition": "Check_ZNF703",
          "distribution": 0.10
        }
      ]
    },
    "Check_TP53": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "has_gene_TP53",
            "operator": "==",
            "value": true
          },
          "transition": "Select_Driver_Gene"
        },
        {
          "transition": "Set_TP53"
        }
      ]
    },
    "Set_TP53": {
      "type": "SetAttribute",
      "attribute": "has_gene_TP53",
      "value": true,
      "direct_transition": "Record_TP53"
    },
    "Record_TP53": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "",
      "codes": [
        {
          "system": "LOINC",
          "code": "69548-6",
          "display": "Genetic variant assessment"
        }
      ],
      "value_code": {
        "system": "SNOMED-CT",
        "code": "10828004",
        "display": "TP53 mutation positive"
      },
      "direct_transition": "Increment_Assigned_Driver_Count"
    },
